{
  "expo": {
    "name": "Hydromate",
    "slug": "hydromate",
    "version": "1.0.0",
    "scheme": "hydromate",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F4FE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.abiarul.hydromate"
    },
    "android": {
      "package": "com.abiarul.hydromate",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#E6F4FE"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Hydromate to use your location to autofill your delivery address."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6f3c290e-75a1-49d5-8e6d-d311f1a54c81"
      }
    },
    "owner": "abinisha03"
  }
}